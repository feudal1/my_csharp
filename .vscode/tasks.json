{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch-ai",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}/ctools/ctool.csproj"
            ],
            "problemMatcher": "$msCompile",
            "isBackground": true,
            "group": "build"
        },
        {
            "label": "build-sw-plugin",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/sw_plugin/sw_plugin.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "start-sldworks-programfiles",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Start-Process 'C:\\Program Files\\SOLIDWORKS Corp\\SOLIDWORKS\\SLDWORKS.exe'; Start-Sleep -Seconds 2"
            ],
            "problemMatcher": []
        },
        {
            "label": "start-sldworks-e-drive",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Start-Process 'E:\\sw\\SOLIDWORKS\\SLDWORKS.exe'; Start-Sleep -Seconds 2"
            ],
            "problemMatcher": []
        }
    ]
}
