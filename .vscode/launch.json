{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "name": ".NET Core Launch (console)",
            "program": "${workspaceFolder}/ctools/bin/Debug/net9.0-windows/ai.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "internalConsoleOptions": "openOnSessionStart",
            "pipeTransport": {
                "pipeCwd": "${workspaceFolder}",
                "pipeProgram": "cmd",
                "pipeArgs": ["/c"],
                "debuggerPath": "C:\\netcoredbg\\netcoredbg.exe",
                "debuggerArgs": ["--interpreter=vscode"],
                "quoteArgs": true
            }
        },
        {
            "name": "sw_plugin: Launch SolidWorks (C:\\Program Files)",
            "type": "coreclr",
            "request": "attach",
            "preLaunchTask": "start-sldworks-programfiles",
            "processId": "${command:pickProcess}"
        },
        {
            "name": "sw_plugin: Launch SolidWorks (E:\\sw)",
            "type": "coreclr",
            "request": "attach",
            "preLaunchTask": "start-sldworks-e-drive",
            "processId": "${command:pickProcess}"
        },
        {
            "name": "sw_plugin: Attach to SolidWorks",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
